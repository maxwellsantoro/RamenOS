{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ramenos.local/schemas/org/board_packet_v0.schema.json",
  "title": "BoardPacketV0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_kind",
    "packet_id",
    "generated_at_unix_ms",
    "repo_sha",
    "authority_level",
    "current_task_ref",
    "active_track",
    "active_task",
    "next_gate",
    "parallel_tracks",
    "context_refs",
    "work_order_refs",
    "handoff_refs",
    "vote_refs",
    "claim_boundary"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "packet_kind": { "const": "board_packet_v0" },
    "packet_id": { "type": "string", "minLength": 1 },
    "generated_at_unix_ms": { "type": "integer", "minimum": 0 },
    "repo_sha": { "type": "string", "minLength": 1 },
    "authority_level": {
      "type": "string",
      "enum": ["A0", "A1", "A2", "A3", "A4", "A5", "A6"]
    },
    "current_task_ref": { "type": "string", "minLength": 1 },
    "active_track": { "type": "string", "minLength": 1 },
    "active_task": { "type": "string", "minLength": 1 },
    "next_gate": { "type": "string", "minLength": 1 },
    "parallel_tracks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "context_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "work_order_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "handoff_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "vote_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "claim_boundary": { "type": "string", "minLength": 1 }
  }
}
