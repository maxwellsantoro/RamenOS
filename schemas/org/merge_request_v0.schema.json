{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ramenos.local/schemas/org/merge_request_v0.schema.json",
  "title": "MergeRequestV0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_kind",
    "merge_request_id",
    "repo_sha",
    "work_order_ref",
    "vote_ref",
    "implementer_role",
    "reviewer_role",
    "required_gates",
    "gate_results",
    "claim_boundary",
    "remote_merge_precondition"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "packet_kind": { "const": "merge_request_v0" },
    "merge_request_id": { "type": "string", "minLength": 1 },
    "repo_sha": { "type": "string", "minLength": 1 },
    "work_order_ref": { "type": "string", "minLength": 1 },
    "vote_ref": { "type": "string", "minLength": 1 },
    "implementer_role": { "type": "string", "minLength": 1 },
    "reviewer_role": { "type": "string", "minLength": 1 },
    "required_gates": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "gate_results": {
      "type": "object",
      "additionalProperties": false,
      "required": ["results"],
      "properties": {
        "results": {
          "type": "object",
          "additionalProperties": { "type": "string", "minLength": 1 }
        }
      }
    },
    "requires_rq": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "doctrine_area": { "type": "string", "minLength": 1 },
    "claim_boundary": { "type": "string", "minLength": 1 },
    "remote_merge_precondition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "branch_protection_configured",
        "merge_credentials_available",
        "honest_outcome"
      ],
      "properties": {
        "branch_protection_configured": { "type": "boolean" },
        "merge_credentials_available": { "type": "boolean" },
        "honest_outcome": {
          "type": "string",
          "enum": ["PASS/LOOP-LOCAL", "PASS/MERGE"]
        }
      }
    }
  }
}
