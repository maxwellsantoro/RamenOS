{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ramenos.local/schemas/org/current_task_v0.schema.json",
  "title": "CurrentTaskV0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "slug",
    "active_track",
    "active_task",
    "work_order_id",
    "handoff_id",
    "vote_id",
    "packet_id",
    "from_role",
    "to_role",
    "work_order_role",
    "vote_role",
    "authority_level",
    "claim_level_allowed",
    "next_gate",
    "requested_output",
    "rollback_plan",
    "claim_boundary",
    "context_refs",
    "context_grant_refs",
    "authorized_new_paths",
    "scope",
    "constraints",
    "required_gates",
    "parallel_tracks",
    "claims",
    "design_evidence_refs",
    "gate_evidence_refs",
    "claim_evidence_refs",
    "hil_evidence_refs",
    "release_evidence_refs"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "slug": { "type": "string", "minLength": 1 },
    "active_track": { "type": "string", "minLength": 1 },
    "active_task": { "type": "string", "minLength": 1 },
    "work_order_id": { "type": "string", "minLength": 1 },
    "handoff_id": { "type": "string", "minLength": 1 },
    "vote_id": { "type": "string", "minLength": 1 },
    "packet_id": { "type": "string", "minLength": 1 },
    "from_role": { "type": "string", "minLength": 1 },
    "to_role": { "type": "string", "minLength": 1 },
    "work_order_role": { "type": "string", "minLength": 1 },
    "vote_role": { "type": "string", "minLength": 1 },
    "authority_level": { "type": "string", "enum": ["A0", "A1", "A2"] },
    "claim_level_allowed": { "type": "string", "minLength": 1 },
    "next_gate": { "type": "string", "minLength": 1 },
    "requested_output": { "type": "string", "minLength": 1 },
    "rollback_plan": { "type": "string", "minLength": 1 },
    "claim_boundary": { "type": "string", "minLength": 1 },
    "context_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "context_grant_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "authorized_new_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "scope": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "required_gates": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "parallel_tracks": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "design_evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "gate_evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "claim_evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "hil_evidence_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "release_evidence_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
