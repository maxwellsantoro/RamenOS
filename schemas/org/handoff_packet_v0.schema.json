{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ramenos.local/schemas/org/handoff_packet_v0.schema.json",
  "title": "HandoffPacketV0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_kind",
    "handoff_id",
    "work_order_id",
    "from_role",
    "to_role",
    "repo_sha",
    "task",
    "context_refs",
    "claims",
    "constraints",
    "requested_output",
    "required_gates"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "packet_kind": { "const": "handoff_packet_v0" },
    "handoff_id": { "type": "string", "minLength": 1 },
    "work_order_id": { "type": "string", "minLength": 1 },
    "from_role": { "type": "string", "minLength": 1 },
    "to_role": { "type": "string", "minLength": 1 },
    "repo_sha": { "type": "string", "minLength": 1 },
    "task": { "type": "string", "minLength": 1 },
    "context_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "source"],
        "properties": {
          "claim": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 }
        }
      }
    },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "requested_output": { "type": "string", "minLength": 1 },
    "required_gates": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
